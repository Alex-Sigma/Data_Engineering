      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "2669740476",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"airflow:PublishMetrics\",\n        \"airflow:CreateWebLoginToken\"\n      ],\n      \"Resource\": \"arn:aws:airflow:eu-north-1:779846818770:environment/student-mwaa-env\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:List*\",\n        \"s3:GetObject*\",\n        \"s3:GetBucket*\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::airflow-student-bucket20250531122847544200000002/*\",\n        \"arn:aws:s3:::airflow-student-bucket20250531122847544200000002\"\n      ]\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"logs:PutLogEvents\",\n        \"logs:GetQueryResults\",\n        \"logs:GetLogRecord\",\n        \"logs:GetLogGroupFields\",\n        \"logs:GetLogEvents\",\n        \"logs:CreateLogStream\",\n        \"logs:CreateLogGroup\"\n      ],\n      \"Resource\": \"arn:aws:logs:eu-north-1:779846818770:log-group:airflow-student-mwaa-env-*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:GetAccountPublicAccessBlock\",\n        \"logs:DescribeLogGroups\",\n        \"eks:DescribeCluster\",\n        \"cloudwatch:PutMetricData\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:SendMessage\",\n        \"sqs:ReceiveMessage\",\n        \"sqs:GetQueueUrl\",\n        \"sqs:GetQueueAttributes\",\n        \"sqs:DeleteMessage\",\n        \"sqs:ChangeMessageVisibility\"\n      ],\n      \"Resource\": \"arn:aws:sqs:eu-north-1:*:airflow-celery-*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"kms:GenerateDataKey*\",\n        \"kms:Encrypt\",\n        \"kms:DescribeKey\",\n        \"kms:Decrypt\"\n      ],\n      \"NotResource\": \"arn:aws:kms:*:779846818770:key/*\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"kms:ViaService\": \"sqs.eu-north-1.amazonaws.com\"\n        }\n      }\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"batch:*\",\n      \"Resource\": \"arn:aws:batch:*:779846818770:*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"ssm:*\",\n      \"Resource\": \"arn:aws:ssm:eu-north-1:779846818770:parameter/*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"logs:*\",\n      \"Resource\": \"arn:aws:logs:eu-north-1:779846818770:log-group:/aws/lambda/*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"cloudwatch:*\",\n      \"Resource\": \"arn:aws:logs:eu-north-1:779846818770:log-group:/aws/lambda/*\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"airflow:PublishMetrics\",\"airflow:CreateWebLoginToken\"],\"Resource\":\"arn:aws:airflow:eu-north-1:779846818770:environment/student-mwaa-env\"},{\"Effect\":\"Allow\",\"Action\":[\"s3:List*\",\"s3:GetObject*\",\"s3:GetBucket*\"],\"Resource\":[\"arn:aws:s3:::airflow-student-bucket20250531122847544200000002/*\",\"arn:aws:s3:::airflow-student-bucket20250531122847544200000002\"]},{\"Effect\":\"Allow\",\"Action\":[\"logs:PutLogEvents\",\"logs:GetQueryResults\",\"logs:GetLogRecord\",\"logs:GetLogGroupFields\",\"logs:GetLogEvents\",\"logs:CreateLogStream\",\"logs:CreateLogGroup\"],\"Resource\":\"arn:aws:logs:eu-north-1:779846818770:log-group:airflow-student-mwaa-env-*\"},{\"Effect\":\"Allow\",\"Action\":[\"s3:GetAccountPublicAccessBlock\",\"logs:DescribeLogGroups\",\"eks:DescribeCluster\",\"cloudwatch:PutMetricData\"],\"Resource\":\"*\"},{\"Effect\":\"Allow\",\"Action\":[\"sqs:SendMessage\",\"sqs:ReceiveMessage\",\"sqs:GetQueueUrl\",\"sqs:GetQueueAttributes\",\"sqs:DeleteMessage\",\"sqs:ChangeMessageVisibility\"],\"Resource\":\"arn:aws:sqs:eu-north-1:*:airflow-celery-*\"},{\"Effect\":\"Allow\",\"Action\":[\"kms:GenerateDataKey*\",\"kms:Encrypt\",\"kms:DescribeKey\",\"kms:Decrypt\"],\"NotResource\":\"arn:aws:kms:*:779846818770:key/*\",\"Condition\":{\"StringLike\":{\"kms:ViaService\":\"sqs.eu-north-1.amazonaws.com\"}}},{\"Effect\":\"Allow\",\"Action\":\"batch:*\",\"Resource\":\"arn:aws:batch:*:779846818770:*\"},{\"Effect\":\"Allow\",\"Action\":\"ssm:*\",\"Resource\":\"arn:aws:ssm:eu-north-1:779846818770:parameter/*\"},{\"Effect\":\"Allow\",\"Action\":\"logs:*\",\"Resource\":\"arn:aws:logs:eu-north-1:779846818770:log-group:/aws/lambda/*\"},{\"Effect\":\"Allow\",\"Action\":\"cloudwatch:*\",\"Resource\":\"arn:aws:logs:eu-north-1:779846818770:log-group:/aws/lambda/*\"}]}",
